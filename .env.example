# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# SUPABASE_URL: Base URL for your Supabase backend REST API
SUPABASE_URL=https://your-supabase-project-id.supabase.co/rest/v1/

# SUPABASE_ANON_KEY: Anonymous public API key for your Supabase backend
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
